    // ###########################################################################################################
    {{#each controllers}}
    {{#each actions}}
        router.{{method}}('{{fullPath}}',
            ...templateService.middlewares({
              controller: {{../name}},
              method: {{../name}}.prototype.{{name}},
              security: {{json security}} as Array<TsoaRoute.Security>,
              uploadInstance: {{#if ../../useFileUploads}}upload{{^}}undefined{{/if}},
              singleUploadFileFields: {{json uploadFileName}},
              filesUploadFieldName: {{#if uploadFiles }}'{{uploadFilesName}}'{{^}}undefined{{/if}},
